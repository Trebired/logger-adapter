{
  "name": "@trebired/logger-adapter",
  "version": "0.2.0",
  "description": "Logger adapter for @trebired/logger-compatible calls with common logger and custom writer support.",
  "license": "MIT",
  "keywords": [
    "logger",
    "logging",
    "adapter",
    "node",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Trebired/logger-adapter"
  },
  "bugs": {
    "url": "https://github.com/Trebired/logger-adapter/issues"
  },
  "homepage": "https://github.com/Trebired/logger-adapter#readme",
  "type": "module",
  "engines": {
    "node": ">=18",
    "bun": ">=1.0.0"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.12",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "demo": "bun run examples/dummy.ts",
    "prepublishOnly": "bun run typecheck && bun test && bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/node": "^24.10.1",
    "typescript": "^6.0.2"
  }
}
